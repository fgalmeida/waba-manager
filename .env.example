# Senha para acessar o painel (defina uma senha forte)
APP_PASSWORD=defina-uma-senha-forte

# Chave para criptografar credenciais e assinar sessoes
# Gere com: openssl rand -base64 32
SESSION_SECRET=gere-com-openssl-rand-base64-32

# Versao da Meta API (nao altere a menos que saiba o que esta fazendo)
META_API_VERSION=v19.0

# Nome publico da aplicacao (aparece no titulo da pagina)
NEXT_PUBLIC_APP_NAME=WhatsApp Template Manager
